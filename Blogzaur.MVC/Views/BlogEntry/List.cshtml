@model IEnumerable<Blogzaur.Application.BlogEntry.BlogEntryDto>
@using System.Globalization
@using Microsoft.AspNetCore.Mvc.Rendering

<head>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css">
</head>

@{
    ViewData["Title"] = "Blog List";
    var searchTitle = ViewBag.SearchTitle as string ?? string.Empty;
    var searchAuthor = ViewBag.SearchAuthor as string ?? string.Empty;
    var selectedCategories = (ViewBag.SelectedCategories as string[]) ?? Array.Empty<string>();
    var sortBy = ViewBag.SortBy as string ?? "date_desc";
    var searchCategories = (ViewBag.SearchCategories as List<SelectListItem>) ?? new List<SelectListItem>();

    // Show the search panel on first render if any filter is active.
    bool initialSearchVisible = !string.IsNullOrWhiteSpace(searchTitle)
                                || !string.IsNullOrWhiteSpace(searchAuthor)
                                || (selectedCategories?.Any() == true)
                                || (sortBy != null && sortBy != "date_desc");
    var searchCardStyle = initialSearchVisible ? "display:block;" : "display:none;";
}

<link rel="stylesheet" href="~/css/list.css" asp-append-version="true" />

<style>
</style>

<h1 class="margin-large" align="center">Blog Entries</h1>

@if (User.Identity?.IsAuthenticated == true)
{
    <div class="mb-4" style="text-align:left;">
        <a class="btn btn-primary btn-sm" asp-controller="BlogEntry" asp-action="Create">Create New Blog</a>
    </div>
}

<div class="mb-2" id="panelToggleTextContainer" style="display:@(initialSearchVisible ? "none" : "block")">
    <div class="d-flex justify-content-start">
        <a id="panelToggleText" class="search-toggle-text small" role="button" aria-expanded="false">
            <span>Show Search →</span>
        </a>
    </div>
</div>

<div class="mb-4 card border-0 shadow-none p-2 small" id="searchCard" style="@searchCardStyle">
    <div class="mb-1">
        <a id="panelHideLink" class="text-decoration-none small" style="cursor:pointer; display:@(initialSearchVisible ? "inline-block" : "none"); color:var(--bs-secondary);">
            Hide Search ↓
        </a>
    </div>

    <form method="get" asp-controller="BlogEntry" asp-action="List" id="searchForm">
        <div class="row g-2 align-items-end">
            <div class="col-md-6">
                <label class="form-label small">Title</label>
                <input name="searchTitle" value="@searchTitle" class="form-control form-control-sm" placeholder="Search by title..." />
            </div>

            <div class="col-md-6">
                <label class="form-label small">Sort by</label>
                <select name="sortBy" class="form-select form-select-sm w-50">
                    <option value="date_desc" selected="@(sortBy == "date_desc" ? "selected" : null)">Date (newest)</option>
                    <option value="date_asc" selected="@(sortBy == "date_asc" ? "selected" : null)">Date (oldest)</option>
                    <option value="views_desc" selected="@(sortBy == "views_desc" ? "selected" : null)">Views (most)</option>
                    <option value="views_asc" selected="@(sortBy == "views_asc" ? "selected" : null)">Views (least)</option>
                    <option value="likes_desc" selected="@(sortBy == "likes_desc" ? "selected" : null)">Likes (most)</option>
                    <option value="likes_asc" selected="@(sortBy == "likes_asc" ? "selected" : null)">Likes (least)</option>
                    <option value="comments_desc" selected="@(sortBy == "comments_desc" ? "selected" : null)">Comments (most)</option>
                    <option value="comments_asc" selected="@(sortBy == "comments_asc" ? "selected" : null)">Comments (least)</option>
                </select>
            </div>
        </div>

        @* Second line: Author + Categories (swapped) *@
        <div class="row g-2 align-items-end mt-2">
            <div class="col-md-5">
                <label class="form-label small">Author</label>
                <input name="searchAuthor" value="@searchAuthor" class="form-control form-control-sm" placeholder="Search by author..." />
            </div>

            <div class="col-md-4">
                <label class="form-label small">Categories (max 3)</label>
                <div class="d-flex">
                    <select id="categoryAddSelect" class="form-select form-select-sm me-2">
                        <option value="">Select category...</option>
                        @foreach (var item in searchCategories)
                        {
                            <option value="@item.Value">@item.Text</option>
                        }
                    </select>
                    <button id="addCategoryBtn" type="button" class="btn btn-primary btn-sm">Add</button>
                </div>
            </div>

            <div class="col-md-3"></div>
        </div>

        @* Badges row placed below the main rows; aligned under the category column *@
        <div class="row mt-2">
            <div class="col-md-5"></div>
            <div class="col-md-4">
                <div id="selectedCategoriesContainer" class="mt-1">
                    @* Pre-render existing selected categories as hidden inputs + removable small badges *@
                    @foreach (var val in selectedCategories)
                    {
                        var text = searchCategories.FirstOrDefault(c => string.Equals(c.Value, val, StringComparison.OrdinalIgnoreCase))?.Text ?? val;
                        <input type="hidden" name="selectedCategories" value="@val" />
                        <span class="badge bg-secondary me-1 selected-category small" data-value="@val">
                            @text
                            <button type="button" class="btn-close btn-close-white btn-sm ms-2 remove-selected-category" aria-label="Remove" data-value="@val"></button>
                        </span>
                    }
                </div>
                <div id="categoryWarning" class="form-text text-danger mt-1" style="display:none; font-size:0.85rem;">You can add up to 3 categories.</div>
            </div>
            <div class="col-md-3"></div>
        </div>

        @* Third line: Search and Clear buttons (moved to the left) *@
        <div class="row g-2 align-items-start mt-2">
            <div class="col-md-5 d-flex gap-2">
                <button type="submit" class="btn btn-primary btn-sm">Search</button>
                <a id="clearBtn" class="btn btn-primary btn-sm" href="@Url.Action("List", "BlogEntry")">Clear</a>
            </div>
            <div class="col-md-4"></div>
            <div class="col-md-3"></div>
        </div>
    </form>
</div>

<div class="blog-grid">
    @foreach (var blog in Model)
    {
        <div class="blog-card" style="min-height:400px;">
            <div class="blog-card-header">
                <span class="blog-title">@blog.Title</span>
            </div>
            <div class="blog-card-meta">
                <span class="blog-author">By @blog.AuthorName</span>
            </div>

            @{
                var categories = blog.Categories ?? new List<string>();
            }
            @if (categories.Any())
            {
                <div class="blog-card-categories mb-2">
                    @foreach (var name in categories)
                    {
                        <span class="badge bg-secondary me-1">@name</span>
                    }
                </div>
            }

            @{
                string createdText = "—";
                var createdProp = blog?.GetType().GetProperty("CreatedAt");
                var createdVal = createdProp?.GetValue(blog);
                if (createdVal is DateTime cdt && cdt != default)
                {
                    createdText = cdt.ToString("f", CultureInfo.GetCultureInfo("en-US"));
                }
                else if (createdVal != null)
                {
                    createdText = createdVal.ToString();
                }

                string viewsText = "0";
                var viewsProp = blog?.GetType().GetProperty("Views");
                var viewsVal = viewsProp?.GetValue(blog);
                if (viewsVal is int vi)
                {
                    viewsText = vi.ToString();
                }
                else if (viewsVal != null)
                {
                    viewsText = viewsVal.ToString();
                }

                // Likes parsing: try common property names used in DTOs
                string likesText = "0";
                var likesProp = blog?.GetType().GetProperty("LikeAmount")
                                ?? blog?.GetType().GetProperty("Likes")
                                ?? blog?.GetType().GetProperty("LikeCount");
                var likesVal = likesProp?.GetValue(blog);
                if (likesVal is int li)
                {
                    likesText = li.ToString();
                }
                else if (likesVal != null)
                {
                    likesText = likesVal.ToString();
                }

                // Comments parsing: try common property names used in DTOs
                string commentsText = "0";
                var commentsProp = blog?.GetType().GetProperty("CommentCount")
                                   ?? blog?.GetType().GetProperty("CommentsCount")
                                   ?? blog?.GetType().GetProperty("Comments")
                                   ?? blog?.GetType().GetProperty("CommentAmount");
                var commentsVal = commentsProp?.GetValue(blog);
                if (commentsVal is int ci)
                {
                    commentsText = ci.ToString();
                }
                else if (commentsVal != null)
                {
                    commentsText = commentsVal.ToString();
                }
            }

            <div class="blog-card-stats mb-2">
                <div class="small text-muted">Created</div>
                <div class="small" style="font-size:0.8em;">@createdText</div>
            </div>

            <hr class="blog-card-divider" style="border:none;border-top:2px solid rgba(0,0,0,0.12);margin:0.5rem 0 1rem;width:100%;" />

            <div class="blog-card-description">
                @blog.Description
            </div>
            <hr class="blog-card-divider" style="border:none;border-top:2px solid rgba(0,0,0,0.12);margin:0.5rem 0 1rem;width:100%;" />

            @* Views, Likes and Comments (left) and Actions (right) on the same line *@
            <div class="d-flex justify-content-between align-items-center mb-2">
                <div class="small text-muted d-flex align-items-center">
                    <i class="fa-solid fa-eye me-2" aria-hidden="true"></i>
                    <span class="fw-medium me-3">@viewsText</span>

                    <i class="fa-solid fa-thumbs-up me-2" aria-hidden="true"></i>
                    <span class="fw-medium me-3">@likesText</span>

                    <i class="fa-solid fa-comment me-2" aria-hidden="true"></i>
                    <span class="fw-medium">@commentsText</span>
                </div>

                <div class="blog-card-actions">
                    @if (blog.isEditable)
                    {
                        <a class="btn btn-primary btn-sm me-2" asp-controller="BlogEntry" asp-action="Edit" asp-route-id="@blog.Id">Edit</a>
                    }
                    <a class="btn btn-primary btn-sm" asp-controller="BlogEntry" asp-action="Details" asp-route-id="@blog.Id">Read</a>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script src="~/js/BlogEntry/List.js" asp-append-version="true"></script>
}