@using Blogzaur.Application.Category.Commands.CreateCategory
@using Blogzaur.Application.Category.Commands.EditCategory
@using Blogzaur.Domain.Entities
@model IEnumerable<Blogzaur.Application.Category.CategoryDto>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4>Manage Categories</h4>
    <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createCategoryModal">New category</button>
</div>

@if (!Model?.Any() ?? true)
{
    <div class="alert alert-secondary">No categories found.</div>
}
else
{
    <table class="table table-sm table-striped">
        <thead>
            <tr>
                <th>Name</th>
                <th style="width:20%;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var c in Model)
            {
                <tr>
                    <td>@c.Name</td>
                    <td>
                        @* Render a button that opens the modal whose id includes the category id.
                           No client JS required — the modal HTML is pre-rendered with the category model. *@
                        <button type="button"
                                class="btn btn-sm btn-primary me-1"
                                data-bs-toggle="modal"
                                data-bs-target="#editCategoryModal_@c.Id">
                            Edit
                        </button>

                        @* Proper POST form with antiforgery token; use a simple, safe confirmation message.
                           Keep confirm on the button itself to avoid extra JS wiring. *@
                        <form asp-controller="Admin" asp-action="RemoveCategory" asp-route-id="@c.Id" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Are you sure you want to delete this category?');">Delete</button>
                        </form>
                    </td>
                </tr>

                @* Render per-category edit modal prepopulated with Id/Name so opening the modal shows values without JS. *@
                @await Html.PartialAsync("_EditCategory", new EditCategoryCommand { Id = c.Id, Name = c.Name })
            }
        </tbody>
    </table>
}

@* Single create modal instance (unchanged) *@
@await Html.PartialAsync("_CreateCategory", new CreateCategoryCommand())

@section Scripts {
    @* Include unobtrusive validation scripts once for the page (required for client validation) *@
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
